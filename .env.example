# ============================================
# RAG System Configuration
# ============================================

# Application Settings
APP_NAME=RAG System
APP_VERSION=1.0.0
DEBUG=true
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ============================================
# Service URLs (All External Services)
# ============================================

# Document Chunking Service
CHUNK_SERVICE_URL=
CHUNK_SERVICE_TIMEOUT=300

# Embedding Service (Qwen3-Embedding-8B)
EMBEDDING_SERVICE_URL=
EMBEDDING_SERVICE_TIMEOUT=120

# Rerank Service (Qwen3-Reranker-8B)
RERANK_SERVICE_URL=
RERANK_SERVICE_TIMEOUT=60

# LLM Service (Gemma-4-26B-A4B-it)
LLM_SERVICE_URL=
LLM_SERVICE_TIMEOUT=120

# Document Storage Service (MySQL + ES + Milvus)
DOCUMENT_SERVICE_URL=
DOCUMENT_SERVICE_TIMEOUT=60

# ============================================
# Model Configuration
# ============================================

# Embedding Model
EMBEDDING_MODEL=

# Rerank Model
RERANK_MODEL=

# LLM Model
LLM_MODEL=

# ============================================
# Ingestion Pipeline Configuration V2
# ============================================

# Chunking Parameters
DEFAULT_CHUNK_SIZE=1024
DEFAULT_CHUNK_OVERLAP=50
DEFAULT_CHUNK_MODE=general
SEMANTIC_SPLIT=true
PRESERVE_HIERARCHY=true

# Parent-Child Mode Parameters (optional)
PARENT_CHUNK_SIZE=1500
CHILD_CHUNK_SIZE=200
CHILD_CHUNK_OVERLAP=20

# V2: Batch size limit for embedding and bulk insert (max 100 per request)
BULK_INSERT_BATCH_SIZE=100

# ============================================
# Query Pipeline Configuration
# ============================================

# Hybrid Search
DEFAULT_TOP_K=15

# Rerank Parameters
RERANK_TOP_N=5
RERANK_THRESHOLD=0.4
RERANK_RETURN_DOCUMENTS=true

# LLM Parameters
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2000

# ============================================
# Retry Configuration
# ============================================

MAX_RETRIES=3
RETRY_DELAY=1.0
RETRY_BACKOFF_FACTOR=2.0
